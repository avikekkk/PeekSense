# UploadThing tokens — one per album defined in albums.config.ts
# Dashboard → API Keys

# Album: "main" (default)
UPLOADTHING_TOKEN=

# Album: "wedding" (example — add to albums.config.ts first)
# UPLOADTHING_TOKEN_WEDDING=

# Album: "travel" (example — add to albums.config.ts first)
# UPLOADTHING_TOKEN_TRAVEL=
